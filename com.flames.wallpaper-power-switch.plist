<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.flames.wallpaper-power-switch</string>

    <key>Program</key>
    <string>__HOME__/.local/bin/wallpaper-power-switch.sh</string>

    <key>StartInterval</key>
    <integer>30</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/wallpaper-power-switch.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/wallpaper-power-switch.err</string>
</dict>
</plist>
